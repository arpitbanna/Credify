    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a sentiment analysis system.\n\nAnalyze the sentiment of the given news.\n\nReturn ONLY valid JSON.\nDo NOT include:\n- markdown\n- backticks\n- ```json\n- explanations\n- extra text\n\nOutput format:\n\n{\n  \"sentiment\": \"Positive or Negative or Neutral\",\n  \"intensity\": \"Low or Medium or High\"\n}\n\nNews:\n{{ $json.body.news }}",
