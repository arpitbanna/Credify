    {
      "parameters": {
        "jsCode": "const data = $input.first().json\n\n// 🔥 FIX: get articles from SerpAPI node\nconst articles = $('Fetch Related News (SerpAPI)').first().json.news_results || []\n\nconst matchedTitles = data.matchedArticles || []\n\n// Step 1: try matched articles\nlet topMatches = articles\n  .filter(a => matchedTitles.includes(a.title))\n  .slice(0, 3)\n\n// Step 2: fallback\nif (topMatches.length === 0) {\n  topMatches = articles.slice(0, 3)\n}\n\n// Step 3: format\ntopMatches = topMatches.map(a => ({\n  title: a.title,\n  source: a.source,\n  link: a.link,\n  image: a.thumbnail || a.image || \"\"\n}))\n\nreturn [{\n  json: {\n    news: $('Receive News Input').first().json.body.news,\n\n    verdict: data.verdict,\n    confidence: data.confidence,\n\n    sentiment: data.sentiment,\n    intensity: data.intensity,\n\n    credibility_score: data.credibility_score,\n\n    top_articles: topMatches,\n\n    disclaimer: \"This result is AI-generated and may not be 100% accurate.\"\n  }\n}]"
      },
